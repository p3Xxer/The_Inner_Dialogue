---
import { getCollection } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import getPostsByGroupCondition from "@/utils/getPostsByGroupCondition";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const groupedPosts = getPostsByGroupCondition(sortedPosts, post =>
  dayjs(post.data.pubDatetime).tz(SITE.timezone).format("YYYY MMMM")
);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section
      id="hero"
      class:list={[
        "flex flex-col items-center pt-10 pb-8 text-center",
        "border-b border-border-subtle",
      ]}
    >
      <div
        aria-hidden="true"
        class="mb-1 font-serif text-[42px] leading-none text-accent-primary opacity-85"
      >
        &ldquo;
      </div>
      <h1
        class="my-2 inline-block font-serif text-3xl font-semibold sm:text-4xl"
      >
        The Inner Dialogue
      </h1>
      <p class="max-w-[44ch] font-serif text-base text-text-secondary italic">
        A space for thinking out loud — notes on software, design, books and the
        things in between.
      </p>
    </section>

    <section id="all-posts" class="pt-8 pb-6">
      {
        Object.entries(groupedPosts).map(([group, groupPosts]) => (
          <div class="mb-10">
            <h2 class="mb-3 text-center font-serif text-[13px] tracking-[0.12em] text-text-muted [font-variant:small-caps]">
              {group}
            </h2>
            <ul>
              {groupPosts.map(post => {
                const date = dayjs(post.data.pubDatetime).tz(SITE.timezone);
                return (
                  <li class="border-b border-border-subtle py-4 text-center last:border-b-0">
                    <a
                      href={getPath(post.id, post.filePath)}
                      class="inline-block font-serif leading-tight font-semibold text-accent-primary underline-offset-4 hover:underline"
                    >
                      {post.data.title}
                    </a>
                    <time
                      datetime={date.toISOString()}
                      class="mt-1.5 block font-meta text-xs tracking-wide text-text-muted uppercase"
                    >
                      {date.format("D MMM, YYYY")}
                    </time>
                  </li>
                );
              })}
            </ul>
          </div>
        ))
      }
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
