---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BookCard from "@/components/BookCard.astro";
import getSortedBooks from "@/utils/getSortedBooks";
import getUniqueGenres from "@/utils/getUniqueGenres";
import { SITE } from "@/config";

const allBooks = await getCollection("library");
const books = getSortedBooks(allBooks);
const genres = getUniqueGenres(allBooks);
---

<Layout title={`Library | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Library" pageDesc="Books I've read." wide>
    <div class="mb-6 flex flex-wrap gap-2">
      <button
        class="genre-filter rounded-full border border-border-subtle px-3 py-1 text-sm transition-colors data-[active]:border-accent-primary data-[active]:text-accent-primary"
        data-genre="all"
        data-active=""
      >
        All
      </button>
      {
        genres.map(({ genre, genreName }) => (
          <button
            class="genre-filter rounded-full border border-border-subtle px-3 py-1 text-sm transition-colors data-[active]:border-accent-primary data-[active]:text-accent-primary"
            data-genre={genre}
          >
            {genreName}
          </button>
        ))
      }
    </div>

    <ul
      id="book-list"
      class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4"
    >
      {books.map(book => <BookCard {...book} />)}
    </ul>
  </Main>

  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const filterBtns =
      document.querySelectorAll<HTMLButtonElement>(".genre-filter");
    const bookList = document.querySelector<HTMLUListElement>("#book-list");

    function applyFilter(selected: string) {
      filterBtns.forEach(b => delete b.dataset.active);
      const activeBtn =
        [...filterBtns].find(b => b.dataset.genre === selected) ?? filterBtns[0];
      activeBtn.dataset.active = "";

      bookList
        ?.querySelectorAll<HTMLLIElement>("li[data-genre]")
        .forEach(card => {
          if (selected === "all") {
            card.hidden = false;
          } else {
            const cardGenres = card.dataset.genre!.split(",");
            card.hidden = !cardGenres.includes(selected);
          }
        });
    }

    // Apply filter from URL on load
    const params = new URLSearchParams(window.location.search);
    applyFilter(params.get("genre") ?? "all");

    filterBtns.forEach(btn => {
      btn.addEventListener("click", () => {
        const selected = btn.dataset.genre!;
        applyFilter(selected);

        // Sync URL without page reload
        const url = new URL(window.location.href);
        if (selected === "all") {
          url.searchParams.delete("genre");
        } else {
          url.searchParams.set("genre", selected);
        }
        history.replaceState({}, "", url.toString());
      });
    });
  });
</script>
