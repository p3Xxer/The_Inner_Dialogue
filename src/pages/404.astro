---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SITE } from "@/config";
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <Header />

  <main
    id="main-content"
    class="app-layout flex flex-1 items-center justify-center"
  >
    <div class="mb-14 flex flex-col items-center justify-center text-center">
      <h1 class="font-serif text-8xl font-semibold text-accent-primary">404</h1>
      <span aria-hidden="true" class="font-meta text-text-muted">
        ¯\_(ツ)_/¯
      </span>
      <p class="mt-4 font-serif text-2xl italic sm:text-3xl">Page Not Found</p>
      <LinkButton
        href="/"
        class="mt-6 font-meta text-sm tracking-wide uppercase underline underline-offset-4"
      >
        Go back home
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>
