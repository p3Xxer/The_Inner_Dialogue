---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import { SITE } from "@/config";

type Props = {
  note: CollectionEntry<"notes">;
};

const { note } = Astro.props;
const { title, description, topic, pubDatetime, modDatetime } = note.data;

const { Content } = await render(note);

const dateStr = (date: Date) =>
  date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
  });

const topicSegments = topic.split("/");
---

<Layout
  title={`${title} | ${SITE.title}`}
  description={description}
  scrollSmooth={true}
>
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
  >
    <p class="font-meta text-xs tracking-wide text-text-muted uppercase">
      <a href="/notes/" class="hover:text-accent-primary">notes</a>{
        topicSegments.map(segment => (
          <>
            <span class="text-accent-primary">{" / "}</span>
            {segment}
          </>
        ))
      }
    </p>
    <h1 class="mt-3 font-serif text-2xl font-semibold sm:text-3xl">{title}</h1>
    <p class="mt-3 font-meta text-xs tracking-wide text-text-muted uppercase">
      Planted {dateStr(pubDatetime)}{
        modDatetime && (
          <>
            <span class="text-accent-primary-muted">{" · "}</span>Last tended{" "}
            {dateStr(modDatetime)}
          </>
        )
      }
    </p>

    <hr class="my-8 border-t border-border-subtle" />

    <article id="article" class="app-prose w-full max-w-app">
      <Content />
    </article>

    <BackToTopButton />
  </main>
  <Footer />
</Layout>
